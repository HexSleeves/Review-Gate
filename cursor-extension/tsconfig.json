{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "module": "node16",
    "moduleResolution": "node16",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "target": "es2022",
    "types": ["node"]
  },
  "include": ["src/**/*.js", "esbuild.js", "tests/**/*.cjs"]
}
